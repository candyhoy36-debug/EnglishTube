<?xml version="1.0" encoding="utf-8"?>
<!--
    Sprint 4 Dictionary BottomSheet.

    Layout shape:
        [drag handle pill]
        [back][word title             ][save][open-in-browser]
        [progress strip]
        [WebView Google Search results]

    Drag handle is the only place that drags the sheet — body drags are
    disabled so the inner WebView keeps its own scroll. The back button
    is visible only when the WebView has navigation history; the system
    Back key follows the same fallback (goBack first, then dismiss).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/dictionary_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btn_dictionary_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/dictionary_history_back"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back"
            android:visibility="gone"
            app:tint="@color/text_primary"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_dictionary_word"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="hello" />

        <ImageButton
            android:id="@+id/btn_dictionary_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/dictionary_save_word"
            android:scaleType="centerInside"
            android:src="@drawable/ic_bookmark"
            app:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btn_dictionary_open_external"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/dictionary_open_external"
            android:scaleType="centerInside"
            android:src="@drawable/ic_open_in_new"
            app:tint="@color/text_secondary" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webview_dictionary"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/dictionary_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_gravity="top"
            android:max="100"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
